,"group":"Notebook Run Groups","when":"config.jupyter.notebookRunGroups.groupCount > 2 && config.jupyter.notebookRunGroups.enabled"},{"command":"jupyter-kernelManager.shutdownKernel","group":"Notebook","when":"config.jupyter.kernelManagement.enabled && false && (jupyter.ispythonorinteractiveeactive || jupyter.isnativeactive)"},{"command":"jupyter.notebookeditor.openContextualHelp","title":"%jupyter.command.jupyter.openContextualHelp.title%","category":"Notebook","enablement":"isWorkspaceTrusted && jupyter.ispythonnotebook && config.jupyter.contextualHelp.enabled"},{"command":"jupyter-kernelManager.restartKernel","title":"Restart Kernel","category":"Notebook","when":"false"}],"notebook/toolbar":[{"command":"vscode-notebook-groups.executeGroup1","group":"navigation/execute@6","when":"config.jupyter.notebookRunGroups.groupCount > 0 && config.jupyter.notebookRunGroups.runIconsOnEditorToolbar && config.jupyter.notebookRunGroups.enabled"},{"command":"vscode-notebook-groups.executeGroup2","group":"navigation/execute@7","when":"config.jupyter.notebookRunGroups.groupCount > 1 && config.jupyter.notebookRunGroups.runIconsOnEditorToolbar && config.jupyter.notebookRunGroups.enabled"},{"command":"vscode-notebook-groups.executeGroup3","group":"navigation/execute@8","when":"config.jupyter.notebookRunGroups.groupCount > 2 && config.jupyter.notebookRunGroups.runIconsOnEditorToolbar && config.jupyter.notebookRunGroups.enabled"}],"notebook/cell/title":[{"command":"vscode-notebook-groups.addGroup1","group":"inline/cell@10","when":"config.jupyter.notebookRunGroups.groupCount > 0 && notebookCellResource not in notebookRunGroups.groupOneCells && config.jupyter.notebookRunGroups.enabled"},{"command":"vscode-notebook-groups.removeGroup1","group":"inline/cell@11","when":"config.jupyter.notebookRunGroups.groupCount > 0 && notebookCellResource in notebookRunGroups.groupOneCells && config.jupyter.notebookRunGroups.enabled"},{"command":"vscode-notebook-groups.executeGroup1","group":"inline/cell@1